<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="google-site-verification" content="dFJkhiHg92CUmVXbZJStAMHa2GnOxlLKmZ055bTOyaU" />
<title>Hari Ganesh | Digital Marketing Specialist</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,900;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --black:   #0a0a0a;
  --black2:  #111111;
  --black3:  #161616;
  --black4:  #1c1c1c;
  --gold:    #c9a84c;
  --gold2:   #e8c96e;
  --gold3:   #a07830;
  --gold-pale: rgba(201,168,76,0.08);
  --gold-border: rgba(201,168,76,0.2);
  --white:   #ffffff;
  --cream:   #f5f0e8;
  --text:    #a0a0a0;
  --muted:   #606060;
  --border:  #222222;
  --heading: #f0f0f0;
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { font-family:"Inter", sans-serif; background:var(--black); color:var(--text); overflow-x:hidden; }

/* ── NOISE TEXTURE overlay ── */
body::before {
  content:""; position:fixed; inset:0; z-index:0; pointer-events:none;
  opacity:0.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
}

/* ── NAV ── */
nav {
  position:fixed; top:0; left:0; width:100%; z-index:200;
  display:flex; align-items:center; justify-content:space-between;
  padding:1.2rem 6%;
  background:rgba(10,10,10,0.92);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--gold-border);
}
.nav-logo {
  font-family:"Playfair Display", serif;
  font-size:1.5rem; font-weight:700;
  text-decoration:none; color:var(--white);
  letter-spacing:1px;
}
.nav-logo span { color:var(--gold); }
.nav-links { display:flex; gap:2.5rem; list-style:none; }
.nav-links a {
  text-decoration:none; color:var(--muted);
  font-size:0.75rem; font-weight:500; letter-spacing:2px;
  text-transform:uppercase; transition:color 0.3s;
}
.nav-links a:hover { color:var(--gold); }
.hamburger { display:none; flex-direction:column; gap:5px; cursor:pointer; z-index:300; }
.hamburger span { display:block; width:24px; height:1.5px; background:var(--gold); transition:all 0.3s; }
.hamburger.open span:nth-child(1){ transform:rotate(45deg) translate(5px,5px); }
.hamburger.open span:nth-child(2){ opacity:0; }
.hamburger.open span:nth-child(3){ transform:rotate(-45deg) translate(5px,-5px); }

/* ── HERO ── */
.hero {
  min-height:100vh;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  text-align:center;
  padding:120px 6% 80px;
  position:relative; overflow:hidden;
}
/* radial gold glow top */
.hero::before {
  content:""; position:absolute; top:-200px; left:50%; transform:translateX(-50%);
  width:800px; height:600px;
  background:radial-gradient(ellipse, rgba(201,168,76,0.12) 0%, transparent 70%);
  pointer-events:none;
}
/* bottom line */
.hero::after {
  content:""; position:absolute; bottom:0; left:10%; right:10%;
  height:1px; background:linear-gradient(90deg, transparent, var(--gold-border), transparent);
}
/* subtle grid */
.hero-grid {
  position:absolute; inset:0; pointer-events:none;
  background-image:
    linear-gradient(var(--gold-border) 1px, transparent 1px),
    linear-gradient(90deg, var(--gold-border) 1px, transparent 1px);
  background-size:80px 80px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
}

.hero-content { position:relative; z-index:2; max-width:860px; }

.hero-eyebrow {
  display:inline-flex; align-items:center; gap:0.8rem;
  font-size:0.68rem; font-weight:600; letter-spacing:4px;
  text-transform:uppercase; color:var(--gold);
  margin-bottom:2rem;
  border:1px solid var(--gold-border);
  padding:0.5rem 1.5rem; border-radius:2px;
  background:var(--gold-pale);
}
.hero-eyebrow::before { content:""; width:20px; height:1px; background:var(--gold); }
.hero-eyebrow::after  { content:""; width:20px; height:1px; background:var(--gold); }

.hero h1 {
  font-family:"Playfair Display", serif;
  font-size:clamp(3.5rem, 9vw, 8rem);
  font-weight:900; line-height:1.0;
  letter-spacing:-3px; margin-bottom:1rem;
}
.hero h1 .hello { display:block; color:var(--muted); font-weight:400; font-style:italic; font-size:0.45em; letter-spacing:2px; margin-bottom:0.3rem; }
.hero h1 .name  { display:block; color:var(--white); }
.hero h1 .name em { color:var(--gold); font-style:normal; }

.hero-tagline {
  font-size:0.78rem; letter-spacing:5px; text-transform:uppercase;
  color:var(--muted); margin:1.5rem 0 2.5rem;
  display:flex; align-items:center; justify-content:center; gap:1rem;
}
.hero-tagline::before, .hero-tagline::after {
  content:""; flex:1; max-width:80px; height:1px; background:var(--gold-border);
}

.hero-sub {
  font-size:1rem; line-height:1.95; color:var(--text);
  max-width:560px; margin:0 auto 3rem; font-weight:300;
}

.hero-btns { display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; }
.btn-gold {
  background:var(--gold); color:var(--black);
  text-decoration:none; padding:1rem 2.5rem;
  font-size:0.72rem; font-weight:700; letter-spacing:2.5px;
  text-transform:uppercase; transition:all 0.3s; border:2px solid var(--gold);
}
.btn-gold:hover { background:transparent; color:var(--gold); }
.btn-ghost {
  background:transparent; color:var(--heading);
  text-decoration:none; padding:1rem 2.5rem;
  font-size:0.72rem; font-weight:600; letter-spacing:2.5px;
  text-transform:uppercase; border:1px solid var(--border); transition:all 0.3s;
}
.btn-ghost:hover { border-color:var(--gold); color:var(--gold); }

/* STATS BAR */
.stats-bar {
  display:flex; margin-top:5rem;
  border:1px solid var(--gold-border);
  background:rgba(201,168,76,0.03);
}
.stat-item {
  flex:1; padding:1.8rem 1.5rem; text-align:center;
  border-right:1px solid var(--gold-border); transition:background 0.3s;
}
.stat-item:last-child { border-right:none; }
.stat-item:hover { background:var(--gold-pale); }
.stat-num {
  font-family:"Playfair Display",serif;
  font-size:2.5rem; font-weight:700; color:var(--gold);
  line-height:1; display:block;
}
.stat-label {
  font-size:0.62rem; letter-spacing:2px; text-transform:uppercase;
  color:var(--muted); display:block; margin-top:0.4rem;
}

/* ── SECTIONS ── */
.section { padding:7rem 6%; position:relative; }
.section.alt { background:var(--black2); }
.section.dark { background:var(--black3); }

/* gold line top of sections */
.section-line {
  position:absolute; top:0; left:6%; right:6%;
  height:1px; background:linear-gradient(90deg, transparent, var(--gold-border), transparent);
}

.sec-tag {
  display:inline-flex; align-items:center; gap:0.7rem;
  font-size:0.65rem; font-weight:700; letter-spacing:4px;
  text-transform:uppercase; color:var(--gold); margin-bottom:0.8rem;
}
.sec-tag::before { content:""; width:30px; height:1px; background:var(--gold); }
.sec-title {
  font-family:"Playfair Display",serif;
  font-size:clamp(2rem,4vw,3rem); font-weight:700;
  color:var(--heading); line-height:1.1; letter-spacing:-0.5px;
}
.sec-rule { width:50px; height:2px; background:var(--gold); margin:1.2rem 0 3.5rem; }

/* centered header */
.center-head { text-align:center; }
.center-head .sec-tag { justify-content:center; }
.center-head .sec-rule { margin:1.2rem auto 3.5rem; }

/* ── ABOUT ── */
.about-grid {
  display:grid; grid-template-columns:320px 1fr; gap:5rem; align-items:start;
}
.id-card {
  background:var(--black3); border:1px solid var(--gold-border);
  position:sticky; top:100px; overflow:hidden;
}
.id-card-top {
  background:var(--gold); padding:2rem 2rem 1.5rem;
  position:relative;
}
.id-card-top::after {
  content:""; position:absolute; bottom:-1px; left:0; right:0;
  height:2px; background:var(--black3);
}
.id-monogram {
  font-family:"Playfair Display",serif;
  font-size:3.5rem; font-weight:900;
  color:var(--black); line-height:1; margin-bottom:0.5rem;
  opacity:0.15; position:absolute; top:1rem; right:1.5rem;
}
.id-name {
  font-family:"Playfair Display",serif;
  font-size:1.3rem; font-weight:700; color:var(--black); position:relative; z-index:1;
}
.id-role {
  font-size:0.65rem; letter-spacing:2px; text-transform:uppercase;
  color:rgba(0,0,0,0.6); font-weight:600; margin-top:0.3rem; position:relative; z-index:1;
}
.id-details { padding:1.5rem 2rem; }
.id-row {
  display:flex; align-items:center; gap:0.8rem;
  padding:0.7rem 0; border-bottom:1px solid var(--border);
  font-size:0.82rem; color:var(--text);
}
.id-row:last-child { border:none; }
.id-row .ico { color:var(--gold); font-size:0.9rem; min-width:18px; }

.highlights-list { display:flex; flex-direction:column; gap:0.8rem; margin-top:1.5rem; }
.hl {
  display:flex; align-items:center; gap:1rem;
  padding:1rem 1.2rem;
  background:var(--black3); border:1px solid var(--border);
  border-left:3px solid var(--gold);
  transition:transform 0.25s, border-color 0.25s;
}
.hl:hover { transform:translateX(6px); border-left-color:var(--gold2); }
.hl .ico { font-size:1.1rem; }
.hl h4 { font-size:0.83rem; font-weight:600; color:var(--heading); }
.hl p  { font-size:0.76rem; color:var(--muted); margin-top:0.1rem; }

.about-body p {
  font-size:0.95rem; line-height:2; color:var(--text);
  margin-bottom:1.3rem; font-weight:300;
}
.about-body strong { color:var(--heading); font-weight:600; }

/* ── SERVICES ── */
.svc-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--gold-border); }
.svc-card {
  background:var(--black2); padding:2.8rem 2.2rem;
  position:relative; overflow:hidden; transition:background 0.35s;
}
.svc-card::before {
  content:""; position:absolute; top:0; left:0; right:0;
  height:2px; background:var(--gold);
  transform:scaleX(0); transform-origin:left; transition:transform 0.4s;
}
.svc-card:hover { background:var(--black3); }
.svc-card:hover::before { transform:scaleX(1); }
.svc-num {
  font-family:"Playfair Display",serif; font-size:4rem; font-weight:900;
  color:var(--gold); opacity:0.07; line-height:1; margin-bottom:-0.8rem;
}
.svc-icon { font-size:1.8rem; margin-bottom:1rem; }
.svc-card h3 {
  font-family:"Playfair Display",serif;
  font-size:1.15rem; font-weight:700; color:var(--heading); margin-bottom:0.8rem;
}
.svc-card p { font-size:0.82rem; color:var(--muted); line-height:1.8; font-weight:300; }
.svc-label {
  display:inline-block; margin-top:1.5rem;
  font-size:0.62rem; letter-spacing:2px; text-transform:uppercase;
  color:var(--gold); border-bottom:1px solid var(--gold-border); padding-bottom:2px;
}

/* ── NUMBERS ── */
.nums-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--gold-border); }
.num-card {
  background:var(--black2); padding:3rem 2rem; text-align:center;
  position:relative; overflow:hidden; transition:background 0.3s;
}
.num-card::after {
  content:""; position:absolute; bottom:0; left:0; right:0;
  height:2px; background:var(--gold);
  transform:scaleY(0); transform-origin:bottom; transition:transform 0.3s;
}
.num-card:hover { background:var(--black3); }
.num-card:hover::after { transform:scaleY(1); }
.num-big {
  font-family:"Playfair Display",serif; font-size:3.5rem; font-weight:700;
  color:var(--gold); line-height:1; display:block; margin-bottom:0.6rem;
}
.num-card h4 { font-size:0.85rem; font-weight:600; color:var(--heading); margin-bottom:0.4rem; }
.num-card p  { font-size:0.76rem; color:var(--muted); font-weight:300; line-height:1.6; }

/* ── TIMELINE ── */
.timeline { position:relative; max-width:820px; }
.timeline::before {
  content:""; position:absolute; left:0; top:0;
  width:1px; height:100%;
  background:linear-gradient(180deg, var(--gold) 0%, var(--gold-border) 60%, transparent 100%);
}
.tl-item { padding-left:2.5rem; margin-bottom:3.5rem; position:relative; }
.tl-dot {
  position:absolute; left:-6px; top:5px;
  width:13px; height:13px; border-radius:50%;
  background:var(--black); border:2px solid var(--gold);
}
.tl-dot.now {
  background:var(--gold);
  box-shadow:0 0 0 4px rgba(201,168,76,0.15), 0 0 12px rgba(201,168,76,0.3);
}
.tl-head { display:flex; justify-content:space-between; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.3rem; }
.tl-role { font-family:"Playfair Display",serif; font-size:1.2rem; font-weight:700; color:var(--heading); }
.tl-period {
  font-size:0.68rem; font-weight:600; letter-spacing:1px;
  color:var(--gold); background:var(--gold-pale); border:1px solid var(--gold-border);
  padding:0.25rem 0.9rem;
}
.tl-period.current { background:var(--gold); color:var(--black); border-color:var(--gold); }
.tl-company { font-size:0.82rem; color:var(--gold); font-weight:500; margin-bottom:0.9rem; opacity:0.8; }
.tl-list { list-style:none; }
.tl-list li {
  font-size:0.85rem; color:var(--text); font-weight:300;
  padding:0.3rem 0 0.3rem 1.3rem; position:relative; line-height:1.75;
}
.tl-list li::before { content:"—"; position:absolute; left:0; color:var(--gold); font-size:0.75rem; top:0.35rem; }
.tl-merged {
  font-size:0.68rem; color:var(--gold);
  background:var(--gold-pale); border:1px solid var(--gold-border);
  display:inline-block; padding:0.2rem 0.9rem; margin-bottom:0.8rem;
}

/* ── SKILLS ── */
.skills-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; }
.skill-group {
  background:var(--black3); border:1px solid var(--border); padding:2rem;
}
.skill-group h3 {
  font-family:"Playfair Display",serif;
  font-size:1rem; font-weight:700; color:var(--heading);
  margin-bottom:1.2rem; padding-bottom:0.8rem;
  border-bottom:1px solid var(--gold-border); letter-spacing:0.5px;
}
.skill-tags { display:flex; flex-wrap:wrap; gap:0.5rem; }
.skill-pill {
  background:transparent; color:var(--text);
  font-size:0.74rem; font-weight:500; letter-spacing:0.5px;
  padding:0.35rem 1rem; border:1px solid var(--border); transition:all 0.3s;
}
.skill-pill:hover { background:var(--gold); color:var(--black); border-color:var(--gold); }

/* ── CERTS ── */
.certs-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
.cert-card {
  display:flex; align-items:center; gap:1rem;
  padding:1.2rem 1.4rem;
  background:var(--black3); border:1px solid var(--border);
  transition:all 0.3s;
}
.cert-card:hover { border-color:var(--gold); transform:translateX(4px); }
.cert-ico {
  width:38px; height:38px;
  background:var(--gold-pale); border:1px solid var(--gold-border);
  display:flex; align-items:center; justify-content:center;
  font-size:1rem; flex-shrink:0;
}
.cert-card p { font-size:0.82rem; font-weight:500; color:var(--text); }

/* ── CONTACT ── */
.contact-section {
  background:var(--black3); padding:7rem 6%;
  position:relative; overflow:hidden;
}
.contact-section::before {
  content:""; position:absolute; top:0; left:50%; transform:translateX(-50%);
  width:600px; height:400px;
  background:radial-gradient(ellipse, rgba(201,168,76,0.07) 0%, transparent 70%);
  pointer-events:none;
}
.contact-inner { max-width:680px; margin:0 auto; text-align:center; position:relative; z-index:1; }
.contact-desc {
  font-size:0.97rem; color:var(--muted); font-weight:300;
  line-height:1.95; margin-bottom:3rem;
}
.contact-links { display:flex; flex-wrap:wrap; justify-content:center; gap:1rem; margin-bottom:3rem; }
.contact-link {
  display:flex; align-items:center; gap:0.7rem;
  background:var(--black2); border:1px solid var(--gold-border);
  padding:0.9rem 1.8rem; color:var(--text); font-size:0.82rem;
  text-decoration:none; transition:all 0.3s; letter-spacing:0.5px;
}
.contact-link:hover { background:var(--gold); border-color:var(--gold); color:var(--black); }

footer {
  background:var(--black3); border-top:1px solid var(--gold-border);
  text-align:center; padding:1.5rem;
  color:var(--muted); font-size:0.7rem; letter-spacing:2px; text-transform:uppercase;
}

/* ── ANIMATIONS ── */
@keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
.hero-content > * { opacity:0; animation:fadeUp 0.8s ease forwards; }
.hero-content > *:nth-child(1){animation-delay:0.1s}
.hero-content > *:nth-child(2){animation-delay:0.3s}
.hero-content > *:nth-child(3){animation-delay:0.5s}
.hero-content > *:nth-child(4){animation-delay:0.65s}
.hero-content > *:nth-child(5){animation-delay:0.8s}
.hero-content > *:nth-child(6){animation-delay:0.95s}

/* ── RESPONSIVE ── */
@media(max-width:1024px){
  .about-grid { grid-template-columns:1fr; gap:3rem; }
  .id-card { position:static; }
  .nums-grid { grid-template-columns:repeat(2,1fr); }
}
@media(max-width:900px){
  .svc-grid { grid-template-columns:repeat(2,1fr); }
  .skills-grid { grid-template-columns:1fr; }
  .certs-grid { grid-template-columns:repeat(2,1fr); }
  .section { padding:5rem 5%; }
}
@media(max-width:600px){
  .hamburger { display:flex; }
  .nav-links {
    display:none; position:fixed; top:0; left:0;
    width:100%; height:100vh;
    background:rgba(10,10,10,0.98);
    flex-direction:column; align-items:center; justify-content:center;
    gap:2.5rem; z-index:250;
  }
  .nav-links.open { display:flex; }
  .nav-links a { font-size:1rem; }
  .hero { padding:100px 5% 60px; }
  .hero h1 { font-size:3.2rem; letter-spacing:-1px; }
  .hero-btns { flex-direction:column; align-items:center; }
  .btn-gold, .btn-ghost { width:100%; text-align:center; }
  .stats-bar { flex-direction:column; }
  .stat-item { border-right:none; border-bottom:1px solid var(--gold-border); }
  .stat-item:last-child { border-bottom:none; }
  .svc-grid { grid-template-columns:1fr; }
  .nums-grid { grid-template-columns:repeat(2,1fr); }
  .certs-grid { grid-template-columns:1fr; }
  .section { padding:3.5rem 5%; }
  .tl-head { flex-direction:column; }
  .contact-links { flex-direction:column; align-items:center; }
  .contact-link { width:100%; justify-content:center; }
}
@media(max-width:380px){
  .hero h1 { font-size:2.6rem; }
  .nums-grid { grid-template-columns:1fr; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" href="#">Hari<span>.</span>Ganesh</a>
  <ul class="nav-links" id="navLinks">
    <li><a href="#about"      onclick="closeMenu()">About</a></li>
    <li><a href="#services"   onclick="closeMenu()">Services</a></li>
    <li><a href="#experience" onclick="closeMenu()">Experience</a></li>
    <li><a href="#skills"     onclick="closeMenu()">Skills</a></li>
    <li><a href="#contact"    onclick="closeMenu()">Contact</a></li>
  </ul>
  <div class="hamburger" id="hamburger" onclick="toggleMenu()">
    <span></span><span></span><span></span>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-content">
    <div class="hero-eyebrow">Digital Marketing Specialist · Bangalore, India</div>
    <h1>
      <span class="hello">Hello, I'm</span>
      <span class="name">Hari <em>Ganesh.</em></span>
    </h1>
    <div class="hero-tagline">SEO · Google Ads · GTM · Content Marketing · Analytics</div>
    <p class="hero-sub">4+ years driving organic growth, B2B leads, and enterprise SEO strategy — delivering honest, measurable results for 30–40 brands across India.</p>
    <div class="hero-btns">
      <a href="#services" class="btn-gold">View My Services</a>
      <a href="#contact"  class="btn-ghost">Get In Touch</a>
    </div>
    <div class="stats-bar">
      <div class="stat-item"><span class="stat-num">4+</span><span class="stat-label">Years Experience</span></div>
